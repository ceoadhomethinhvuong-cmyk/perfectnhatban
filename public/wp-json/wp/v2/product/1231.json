th\u01b0\u1eddng l\u00e0 03 \u2013 05 l\u1ea7n, kho\u1ea3ng c\u00e1ch gi\u1eefa c\u00e1c l\u1ea7n TCA kho\u1ea3ng 30 ng\u00e0y.<\/li>\n<\/ul>\n","protected":false},"excerpt":{"rendered":"<p><em>Li\u1ec7u tr\u00ecnh chuy\u00ean bi\u1ec7t cho da s\u1eb9o l\u00f5m d\u1ea1ng ch\u00e2n kim<\/em><\/p>\n","protected":false},"featured_media":3660,"comment_status":"open","ping_status":"closed","template":"","meta":{"_acf_changed":false},"product_brand":[],"product_cat":[40],"product_tag":[],"class_list":{"0":"post-1231","1":"product","2":"type-product","3":"status-publish","4":"has-post-thumbnail","6":"product_cat-seo","8":"first","9":"instock","10":"shipping-taxable","11":"product-type-simple"},"acf":[],"_links":{"self":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product\/1231","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product"}],"about":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/types\/product"}],"replies":[{"embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/comments?post=1231"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/media\/3660"}],"wp:attachment":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/media?parent=1231"}],"wp:term":[{"taxonomy":"product_brand","embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product_brand?post=1231"},{"taxonomy":"product_cat","embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product_cat?post=1231"},{"taxonomy":"product_tag","embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product_tag?post=1231"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}