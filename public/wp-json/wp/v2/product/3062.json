irth &amp; Recovery Mask h\u1ed7 tr\u1ee3 d\u1ecbu da, c\u1ea5p \u1ea9m, gi\u1ea3m t\u00ecnh tr\u1ea1ng k\u00edch \u1ee9ng \u0111\u1ecf da t\u1ee9c th\u00ec, duy tr\u00ec l\u00e0n da kho\u1ebb m\u1ea1nh.<\/li>\n<\/ul>\n<h3>Th\u1eddi gian li\u1ec7u tr\u00ecnh:<\/h3>\n<ul>\n<li>Qu\u00e1 tr\u00ecnh th\u1ef1c hi\u1ec7n 60 ph\u00fat.<\/li>\n<li>M\u1ed9t li\u1ec7u tr\u00ecnh th\u01b0\u1eddng t\u1eeb 03 &#8211; 05 bu\u1ed5i, kho\u1ea3ng c\u00e1ch gi\u1eefa c\u00e1c bu\u1ed5i c\u00e1ch nhau 07 ng\u00e0y.<\/li>\n<\/ul>\n","protected":false},"excerpt":{"rendered":"<p><em>T\u1ed1i \u01b0u cho da \u0111\u1ecf, r\u00e1t, ph\u00f9 n\u1ec7, nh\u1ea1y c\u1ea3m, c\u1ea7n \u0111\u01b0\u1ee3c l\u00e0m d\u1ecbu ph\u1ee5c h\u1ed3i kh\u1ea9n c\u1ea5p.<\/em><\/p>\n","protected":false},"featured_media":3705,"comment_status":"open","ping_status":"closed","template":"","meta":{"_acf_changed":false},"product_brand":[],"product_cat":[38],"product_tag":[],"class_list":{"0":"post-3062","1":"product","2":"type-product","3":"status-publish","4":"has-post-thumbnail","6":"product_cat-phuc-hoi","8":"first","9":"instock","10":"shipping-taxable","11":"product-type-simple"},"acf":[],"_links":{"self":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product\/3062","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product"}],"about":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/types\/product"}],"replies":[{"embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/comments?post=3062"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/media\/3705"}],"wp:attachment":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/media?parent=3062"}],"wp:term":[{"taxonomy":"product_brand","embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product_brand?post=3062"},{"taxonomy":"product_cat","embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product_cat?post=3062"},{"taxonomy":"product_tag","embeddable":true,"href"