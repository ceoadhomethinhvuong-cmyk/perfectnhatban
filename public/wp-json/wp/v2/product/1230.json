 kho\u1ea3ng 30 ng\u00e0y.<\/li>\n<\/ul>\n","protected":false},"excerpt":{"rendered":"<p><em>Li\u1ec7u ph\u00e1p gi\u00fap t\u1ea1i t\u00e1o t\u1ebf b\u00e0o da b\u1ecb t\u1ed5ng th\u01b0\u01a1ng do \u1ea3nh h\u01b0\u1edfng l\u00e3o ho\u00e1, tu\u1ed5i t\u00e1c, t\u00e1c \u0111\u1ed9ng m\u00f4i tr\u01b0\u1eddng.<\/em><\/p>\n","protected":false},"featured_media":3685,"comment_status":"open","ping_status":"closed","template":"","meta":{"_acf_changed":false},"product_brand":[],"product_cat":[59],"product_tag":[],"class_list":{"0":"post-1230","1":"product","2":"type-product","3":"status-publish","4":"has-post-thumbnail","6":"product_cat-advanced-skincare-therapy","8":"first","9":"instock","10":"virtual","11":"product-type-simple"},"acf":[],"_links":{"self":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product\/1230","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product"}],"about":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/types\/product"}],"replies":[{"embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/comments?post=1230"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/media\/3685"}],"wp:attachment":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/media?parent=1230"}],"wp:term":[{"taxonomy":"product_brand","embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product_brand?post=1230"},{"taxonomy":"product_cat","embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product_cat?post=1230"},{"taxonomy":"product_tag","embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product_tag?post=1230"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}