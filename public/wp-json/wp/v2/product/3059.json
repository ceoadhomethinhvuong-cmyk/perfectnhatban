ng l\u00e0 03 \u2013 05 l\u1ea7n, kho\u1ea3ng c\u00e1ch gi\u1eefa c\u00e1c l\u1ea7n kho\u1ea3ng 30 ng\u00e0y.<\/li>\n<\/ul>\n<div id=\"gtx-trans\" style=\"position: absolute; left: -14px; top: 318.349px;\">\n<div class=\"gtx-trans-icon\"><\/div>\n<\/div>\n","protected":false},"excerpt":{"rendered":"<p><em>Ph\u00e1c \u0111\u1ed3 chuy\u00ean bi\u1ec7t d\u00e0nh ri\u00eang cho m\u1ee5n nh\u00e2n, s\u1ea9n vi\u00eam v\u1edbi n\u1ec1n da kho\u1ebb<\/em><\/p>\n","protected":false},"featured_media":3641,"comment_status":"open","ping_status":"closed","template":"","meta":{"_acf_changed":false},"product_brand":[],"product_cat":[36],"product_tag":[],"class_list":{"0":"post-3059","1":"product","2":"type-product","3":"status-publish","4":"has-post-thumbnail","6":"product_cat-mun","8":"first","9":"instock","10":"virtual","11":"product-type-simple"},"acf":[],"_links":{"self":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product\/3059","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product"}],"about":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/types\/product"}],"replies":[{"embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/comments?post=3059"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/media\/3641"}],"wp:attachment":[{"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/media?parent=3059"}],"wp:term":[{"taxonomy":"product_brand","embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product_brand?post=3059"},{"taxonomy":"product_cat","embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product_cat?post=3059"},{"taxonomy":"product_tag","embeddable":true,"href":"https:\/\/gsccos.vn\/wp-json\/wp\/v2\/product_tag?post=3059"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}